---
const { t, lang } = Astro.props;
import ProjectCard from './ProjectCard.astro';
import projectsData from '../data/projects.json';

// Get projects for current language
const projects = projectsData[lang as keyof typeof projectsData] || projectsData.es;
const featuredProjects = projects.filter(p => p.featured);
---
<section id="projects" class="py-12 relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-8 lg:px-20">
  <div class="flex flex-col gap-2 mb-12">
    <div class="flex items-center gap-3">
      <span class="h-px w-12 bg-linear-to-r from-primary to-transparent"></span>
      <h2 class="text-primary font-bold tracking-wider uppercase text-sm">{
      t('proj.title')}</h2>
    </div>
    <h3 class="text-3xl md:text-5xl font-black text-white tracking-tight">{lang === 'es' ? t('proj.subtitle') : t('proj.title')} <span class="text-transparent bg-clip-text bg-linear-to-r from-primary to-blue-400">{ lang ==="es" ? t('proj.title'): t('proj.subtitle')}</span></h3>
  </div>

  <!-- Featured Projects Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 mb-12">
    {featuredProjects.map((project, index) => (
      <ProjectCard project={project} index={index} lang={lang} />
    ))}
  </div>

  <!-- View All Projects Button -->
  <div class="flex justify-center w-full">
    <a 
      href={`/${lang}/projects`} 
      class="group relative inline-flex items-center gap-3 px-8 py-3 bg-transparent overflow-hidden rounded-full border border-primary/30 text-primary hover:text-background-dark font-bold tracking-widest uppercase text-xs transition-all duration-300 hover:border-primary hover:bg-primary hover:shadow-[0_0_20px_rgba(100,252,242,0.4)]"
    >
      <span class="relative z-10">{t('proj.viewAll')}</span>
      <span class="material-symbols-outlined text-lg relative z-10 transition-transform group-hover:translate-x-1" aria-hidden="true">arrow_forward</span>
    </a>
  </div>
</section>
